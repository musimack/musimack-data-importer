MUSIMACK_GA4_PROPERTY_ID=123456789

# Recommended local auth method: Google Workspace internal OAuth desktop client.
MUSIMACK_GA4_AUTH_METHOD=oauth
MUSIMACK_GA4_OAUTH_CLIENT_SECRETS=C:\path\to\oauth-client-secrets.json
MUSIMACK_GA4_OAUTH_TOKEN_FILE=.secrets\ga4-oauth-token.json

# Optional fallback auth method:
# MUSIMACK_GA4_AUTH_METHOD=service_account
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
# Alternative to GOOGLE_APPLICATION_CREDENTIALS. Store the complete service account JSON in this env var.
# MUSIMACK_GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

MUSIMACK_PORTAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/musimack_portal
MUSIMACK_PORTAL_PROJECT_ID=00000000-0000-0000-0000-000000000000
