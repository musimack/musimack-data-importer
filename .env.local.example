# Copy this file to .env.local and fill in local operator values.
# Keep OAuth client JSON and token JSON outside this repo.
# Do not paste OAuth token contents, client secret JSON contents, or raw provider payloads here.

MUSIMACK_GA4_AUTH_METHOD=oauth
MUSIMACK_GA4_OAUTH_CLIENT_SECRETS=C:\path\outside\repos\ga4-oauth-client.json
MUSIMACK_GA4_OAUTH_TOKEN_FILE=C:\path\outside\repos\ga4-oauth-token.json

# GSC can reuse the same OAuth client secrets file as GA4, but must use a separate token file.
MUSIMACK_GSC_OAUTH_CLIENT_SECRETS=C:\path\outside\repos\ga4-oauth-client.json
MUSIMACK_GSC_OAUTH_TOKEN_FILE=C:\path\outside\repos\gsc-token.local.json

MUSIMACK_PORTAL_DATABASE_URL=postgresql://user:password@localhost:5432/musimack_client_portal
